{
	"name": "@pradeepjadhav/trading-reload-chart",
	"version": "1.0.0",
	"description": "A React canvas-based trading chart library with candles, volume, drawing tools, and trade overlays.",
	"keywords": [
		"trading",
		"chart",
		"react",
		"canvas",
		"candlestick",
		"technical-analysis",
		"finance",
		"tradingview"
	],
	"homepage": "https://github.com/Pradeep17Jadhav/trading-reload-chart#readme",
	"bugs": {
		"url": "https://github.com/Pradeep17Jadhav/trading-reload-chart/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Pradeep17Jadhav/trading-reload-chart.git"
	},
	"license": "SEE LICENSE IN LICENSE",
	"author": "Pradeep Jadhav",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "npm run build:library",
		"build:library": "tsc && vite build --mode library",
		"prepack": "npm run build:library",
		"build:demo": "tsc && vite build",
		"preview": "vite preview",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit"
	},
	"peerDependencies": {
		"react": "^18.3.1 || ^19.0.0",
		"react-dom": "^18.3.1 || ^19.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"@vitejs/plugin-react": "^5.0.0",
		"esbuild": "^0.28.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"typescript": "~6.0.2",
		"vite": "^8.0.12",
		"vite-plugin-dts": "^4.5.4"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/trading-reload-chart.js",
			"default": "./dist/trading-reload-chart.js"
		}
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=18"
	},
	"main": "./dist/trading-reload-chart.js",
	"module": "./dist/trading-reload-chart.js",
	"types": "./dist/index.d.ts"
}
